APP_NAME=SaaS RAG Agent
APP_ENV=development
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
CACHE_TTL_SECONDS=86400
SESSION_TTL_SECONDS=7200
FREE_USER_DAILY_LIMIT=10
SIMILARITY_THRESHOLD=0.75
CLAUDE_MODEL=claude-3-5-sonnet-20240620
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.2
OPENROUTER_API_KEY=
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_REASONING_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_CODING_MODEL=deepseek/deepseek-chat
OPENROUTER_FAST_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=512
OPENROUTER_FAST_MAX_TOKENS=256
OPENROUTER_VISION_MODEL=google/gemini-1.5-pro
OPENROUTER_CONTEXT_MAX_CHARS=12000
OPENROUTER_FAST_CONTEXT_MAX_CHARS=3000
TRANSLATION_PROVIDER=stub
WEB_SEARCH_PROVIDER=duckduckgo
DUCKDUCKGO_MAX_RESULTS=5
VECTOR_DB_PROVIDER=memory
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/rag
CHROMA_COLLECTION=rag-documents
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
